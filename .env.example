# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cybersec_agent
POSTGRES_DB=cybersec_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LLM Provider
LLM_PROVIDER=openai

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# Scanner integrations
# When the API runs in Docker, use host.docker.internal for tools on your machine.
SONARQUBE_BASE_URL=http://host.docker.internal:9000
SONARQUBE_TOKEN=your-sonarqube-token-here
ZAP_BASE_URL=http://host.docker.internal:8080
ZAP_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
