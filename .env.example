# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cybersec_agent
POSTGRES_DB=cybersec_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LLM Provider
LLM_PROVIDER=openai

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# App
APP_ENV=development
LOG_LEVEL=INFO
